{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "智投简历桌面端",
  "version": "0.1.0",
  "identifier": "com.zhitoujianli.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "智投简历桌面端",
        "width": 560,
        "height": 720,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/agent/boss_local_agent.py",
      "resources/agent/requirements.txt"
    ]
  }
}
